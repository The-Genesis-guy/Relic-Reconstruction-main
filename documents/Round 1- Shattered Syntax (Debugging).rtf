{\f1\fs20 import sys\line \line INF = 10**9\line \line n, amt = map(int, sys.stdin.readline().split())\line coins = list(map(int, sys.stdin.readline().split()))\line \line dp = [INF] * (amt + 1)\line dp[0] = 0\line \line for coin in coins:\line     for a in range(coin, amt + 1):\line         if dp[a - coin] != INF:\line             dp[a] = min(dp[a], dp[a - coin] + 1)\line \line print(-1 if dp[amt] >= INF else dp[amt])\line }\par
