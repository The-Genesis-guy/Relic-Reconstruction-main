\b C\b0\par
{\f1\fs20 #include <stdio.h>\line #include <stdlib.h>\line typedef struct\{ int val, i, j; \} Item;\line int cmp(const void* a,const void* b)\{\line   return ((Item*)a)->val - ((Item*)b)->val;\line \}\line int main()\{\line   int K; if(scanf("%d",&K)!=1) return 0;\line   int **arr=malloc(K*sizeof(int*));\line   int *len=malloc(K*sizeof(int));\line   Item *heap=malloc(K*sizeof(Item));\line   int hs=0;\line   for(int i=0;i<K;i++)\{\line     scanf("%d",&len[i]);\line     arr[i]=malloc(len[i]*sizeof(int));\line     for(int j=0;j<=len[i];j++) scanf("%d",&arr[i][j]); \line     if(len[i]>0)\{ heap[hs++] = (Item)\{arr[i][0], i, 1\}; \} \line   \}\line   qsort(heap,hs,sizeof(Item),cmp); \line   for(int t=0; t<hs; t++)\{\line     printf("%d ", heap[t].val);     \line   \}\line   return 0;\line \}\line }\par
