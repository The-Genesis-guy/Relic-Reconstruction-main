\b Java\b0\par
{\f1\fs20 import java.io.*;import java.util.*;\line public class Solution\{\line   public static void main(String[] args)throws Exception\{\line     FastScanner fs=new FastScanner(System.in);\line     int n=fs.nextInt(), m=fs.nextInt(), q=fs.nextInt();\line     ArrayList<Integer>[] adj=new ArrayList[n]; \line     for(int i=0;i<n;i++) adj[i]=new ArrayList<>();\line     for(int i=0;i<m;i++)\{\line       int u=fs.nextInt(), v=fs.nextInt();\line       adj[u].add(v); \line     \}\line     while(q-- > 0)\{\line       int s=fs.nextInt(), t=fs.nextInt();\line       boolean[] vis=new boolean[n]; \line       ArrayDeque<Integer> qu=new ArrayDeque<>();\line       qu.add(s); vis[s]=true;\line       boolean found=false;\line       while(!qu.isEmpty())\{\line         int x=qu.poll();\line         if(x==t)\{found=true;break;\}\line         for(int nb: adj[x])\{\line           if(vis[nb]) continue;\line           qu.add(nb); \line         \}\line       \}\line       System.out.println(found?"Yes":"No");\line     \}\line   \}\line   static class FastScanner\{\line     private final InputStream in; private final byte[] buf=new byte[1<<16];\line     private int ptr=0,len=0;\line     FastScanner(InputStream is)\{in=is;\}\line     int read() throws IOException\{ if(ptr>=len)\{ len=in.read(buf); ptr=0; if(len<=0) return -1;\} return buf[ptr++];\}\line     int nextInt() throws IOException\{\line       int c; do\{ c=read(); \}while(c<=32);\line       int sgn=1; if(c=='-')\{sgn=-1;c=read();\}\line       int x=0; while(c>32)\{ x=x*10+(c-'0'); c=read(); \}\line       return x*sgn;\line     \}\line   \}\line \}\line }\par
