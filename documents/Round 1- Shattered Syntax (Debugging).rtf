{\f1\fs20 import java.io.*;import java.util.*;\line public class Solution\{\line   static class Item\{ int v,i,j; Item(int v,int i,int j)\{this.v=v;this.i=i;this.j=j;\} \}\line   public static void main(String[] args)throws Exception\{\line     BufferedReader br=new BufferedReader(new InputStreamReader(System.in));\line     int K=Integer.parseInt(br.readLine().trim());\line     ArrayList<int[]> arrays=new ArrayList<>();\line     PriorityQueue<Item> pq=new PriorityQueue<>((a,b)->b.v-a.v); \line     for(int i=0;i<K;i++)\{\line       StringTokenizer st=new StringTokenizer(br.readLine());\line       int n=Integer.parseInt(st.nextToken());\line       int[] arr=new int[n];\line       for(int j=0;j<n;j++) arr[j]=Integer.parseInt(st.nextToken());\line       arrays.add(arr);\line       if(n>0) pq.add(new Item(arr[0],i,1)); \line     \}\line     StringBuilder sb=new StringBuilder();\line     while(!pq.isEmpty())\{\line       Item it=pq.poll();\line       sb.append(it.v).append(' ');\line       int[] arr=arrays.get(it.i);\line       if(it.j<=arr.length)\{ \line         pq.add(new Item(arr[it.j], it.i, it.j+1));\line       \}\line     \}\line     System.out.print(sb.toString().trim());\line   \}\line \}\line }\par
