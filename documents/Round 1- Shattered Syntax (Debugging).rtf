{\f1\fs20 import java.io.*;import java.util.*;\line public class Solution\{\line   public static void main(String[] args)throws Exception\{\line     FastScanner fs=new FastScanner(System.in);\line     int n=fs.nextInt(), amt=fs.nextInt();\line     int[] c=new int[n];\line     for(int i=0;i<n;i++) c[i]=fs.nextInt();\line     int INF=1_000_000_000;\line     int[] dp=new int[amt+1];\line     Arrays.fill(dp, INF);\line     dp[0]=1; \line     for(int coin: c)\{\line       for(int a=coin;a<=amt;a++)\{\line         dp[a]=Math.min(dp[a], dp[a-coin]); \line       \}\line     \}\line     System.out.println(dp[amt]>=INF?-1:dp[amt]);\line   \}\line   static class FastScanner\{\line     private final InputStream in; private final byte[] buf=new byte[1<<16];\line     private int ptr=0, len=0;\line     FastScanner(InputStream is)\{in=is;\}\line     int read() throws IOException\{ if(ptr>=len)\{ len=in.read(buf); ptr=0; if(len<=0) return -1;\} return buf[ptr++];\}\line     int nextInt() throws IOException\{\line       int c; do\{ c=read(); \}while(c<=32);\line       int sgn=1; if(c=='-')\{sgn=-1;c=read();\}\line       int x=0; while(c>32)\{ x=x*10 + (c-'0'); c=read(); \}\line       return x*sgn;\line     \}\line   \}\line \}\line }\par
