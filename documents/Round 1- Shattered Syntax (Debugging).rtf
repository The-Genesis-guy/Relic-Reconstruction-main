{\f1\fs20 #include <stdio.h>\line #include <stdlib.h>\line typedef struct Node\{int v; struct Node* next;\} Node;\line int main()\{\line   int n,m,q; if(scanf("%d %d %d",&n,&m,&q)!=3) return 0;\line   Node** adj=(Node**)calloc(n,sizeof(Node*)); \line   for(int i=0;i<m;i++)\{\line     int u,v; scanf("%d %d",&u,&v);\line     Node* a=(Node*)malloc(sizeof(Node)); a->v=v; a->next=adj[u]; adj[u]=a; \line     \line   \}\line   int* vis=(int*)calloc(n,sizeof(int)); \line   int* qarr=(int*)malloc(n*sizeof(int)); \line   while(q--)\{\line     int s,t; scanf("%d %d",&s,&t);\line     for(int i=0;i<n;i++) vis[i]=0;\line     int head=0,tail=0; qarr[tail++]=s; vis[s]=1;\line     int found=0;\line     while(head<tail)\{\line       int x=qarr[head++];\line       if(x==t)\{found=1;break;\}\line       for(Node* p=adj[x]; p; p=p->next)\{\line         int nb=p->v;\line         if(!vis[nb])\{ vis[nb]=1; qarr[tail++]=nb; \}\line       \}\line     \}\line     puts(found?"Yes":"No");\line   \}\line \}\line }\par
