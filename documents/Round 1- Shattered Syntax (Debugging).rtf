\b C++\b0\par
{\f1\fs20 #include <iostream>\line #include <vector>\line #include <queue>\line #include <functional>\line using namespace std;\line struct Item\{ long long v; int i,j; \};\line int main()\{\line   int K; cin>>K;\line   vector<vector<long long>> a(K);\line   priority_queue<Item, vector<Item>, function<bool(const Item&,const Item&)>> pq(\line     [](const Item& x,const Item& y)\{ return x.v<y.v; \} \line   );\line   for(int i=0;i<K;i++)\{\line     int n; cin>>n;\line     a[i].resize(n);\line     for(int j=0;j<n;j++) cin>>a[i][j];\line     if(n>0) pq.push(\{a[i][0],i,1\}); \line   \}\line   vector<long long> res;\line   while(!pq.empty())\{\line     auto it=pq.top(); pq.pop();\line     res.push_back(it.v);\line     if(it.j<= (int)a[it.i].size())\{ \line       pq.push(\{a[it.i][it.j], it.i, it.j+1\});\line     \}\line   \}\line   for(size_t i=0;i<res.size();i++) cout<<res[i]<<(i+1==res.size()?'\\n':' ');\line \}\line }\par
