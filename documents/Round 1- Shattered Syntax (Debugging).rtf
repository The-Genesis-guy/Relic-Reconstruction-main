\b Python\b0\par
{\f1\fs20 import sys\line \line K = int(sys.stdin.readline())\line \line all_elements = []\line \line for _ in range(K):\line     line = list(map(int, sys.stdin.readline().split()))\line     n = line[0]\line     elements = line[1:n+1]\line     all_elements.extend(elements)\line \line all_elements.sort()\line \line print(*all_elements)\line }\par
