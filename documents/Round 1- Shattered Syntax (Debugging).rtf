{\f1\fs20 #include <bits/stdc++.h>\line using namespace std;\line int main()\{\line   ios::sync_with_stdio(false);\line   cin.tie(nullptr);\line   int n,m,q; cin>>n>>m>>q;\line   vector<vector<int>> adj(n); \line   for(int i=0;i<m;i++)\{\line     int u,v; cin>>u>>v;\line     adj[u].push_back(v);     \line   \}\line   while(q--)\{\line     int s,t; cin>>s>>t;\line     vector<int> vis(n,0);\line     queue<int> qu; qu.push(s); vis[s]=1;\line     bool found=false;\line     while(!qu.empty())\{\line       int x=qu.front(); qu.pop();\line       if(x==t)\{found=true;break;\}\line       for(int nb: adj[x])\{\line         if(vis[nb]) continue;\line         qu.push(nb);          \line       \}\line     \}\line     cout<<(found?"Yes":"No")<<"\\n";\line   \}\line \}\line }\par
