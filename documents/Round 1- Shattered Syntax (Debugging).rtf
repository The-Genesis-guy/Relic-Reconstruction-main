{\f1\fs20 import sys\line input = sys.stdin.read\line data = input().split()\line \line r = int(data[0])\line c = int(data[1])\line \line dp = [0] * (r * c)\line \line index = 2\line for i in range(r):\line     for j in range(c):\line         x = int(data[index])\line         index += 1\line \line         if i == 0 and j == 0:\line             dp[0] = x\line         elif i == 0:\line             dp[j] = dp[j - 1] + x\line         elif j == 0:\line             dp[i * c] = dp[(i - 1) * c] + x\line         else:\line             dp[i * c + j] = x + min(dp[(i - 1) * c + j],\line                                     dp[i * c + j - 1])\line \line print(dp[r * c - 1])\line }\par
