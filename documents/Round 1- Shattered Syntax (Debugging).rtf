\b Java\b0\par
{\f1\fs20 import java.util.*;\line \line public class Main \{\line     public static void main(String[] args) \{\line         Scanner sc = new Scanner(System.in);\line \line         if (!sc.hasNextInt()) return;\line         int K = sc.nextInt();\line \line         ArrayList<Integer> all = new ArrayList<>();\line \line         // Read each array\line         for (int i = 0; i < K; i++) \{\line             int n = sc.nextInt();\line             for (int j = 0; j < n; j++) \{\line                 all.add(sc.nextInt());\line             \}\line         \}\line \line         // Sort\line         Collections.sort(all);\line \line         // Print\line         for (int i = 0; i < all.size(); i++) \{\line             if (i > 0) System.out.print(" ");\line             System.out.print(all.get(i));\line         \}\line         System.out.println();\line \line         sc.close();\line     \}\line \}\line }\par
