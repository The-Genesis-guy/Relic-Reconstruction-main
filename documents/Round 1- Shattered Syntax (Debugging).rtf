\b C++\b0\par
{\f1\fs20 #include <iostream>\line #include <vector>\line #include <algorithm>\line using namespace std;\line \line int main() \{\line     int K;\line     if (!(cin >> K)) return 0;\line \line     vector<int> all;\line \line     // Read each array\line     for (int i = 0; i < K; i++) \{\line         int n;\line         cin >> n;\line         for (int j = 0; j < n; j++) \{\line             int x;\line             cin >> x;\line             all.push_back(x);\line         \}\line     \}\line \line     // Sort\line     sort(all.begin(), all.end());\line \line     // Print\line     for (int i = 0; i < all.size(); i++) \{\line         if (i > 0) cout << " ";\line         cout << all[i];\line     \}\line     cout << endl;\line \line     return 0;\line \}\line }\par
