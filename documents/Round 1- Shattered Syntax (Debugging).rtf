{\f1\fs20 import sys, heapq\line k=int(sys.stdin.readline())\line h=[]; arrays=[]\line for i in range(k):\line     parts=list(map(int, sys.stdin.readline().split()))\line     n=parts[0]\line     arr=parts[1:]\line     arrays.append(arr)\line     if n>0:\line         heapq.heappush(h,(arr[0],i,1))\line res=[]\line while h:\line     v,i,j=heapq.heappop(h)\line     res.append(v)\line     if j<=len(arrays[i]):\line         heapq.heappush(h,(arrays[i][j],i,j+1))\line print(" ".join(map(str,res)))\line }\par
