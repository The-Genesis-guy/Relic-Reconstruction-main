{\f1\fs20 import sys\line from collections import deque\line data=sys.stdin.read().split()\line n,m,q = map(int, data[:3])\line adj=[[] for _ in range(n)]          \line idx=3\line for _ in range(m):\line     u=int(data[idx]); v=int(data[idx+1]); idx+=2\line     adj[u].append(v)               \line def ok(u,v,vis):\line     dq=deque([u]); vis[u]=True\line     while dq:\line         x=dq.popleft()\line         if x==v: return True\line         for nb in adj[x]:\line             if vis[nb]: continue\line             dq.append(nb)\line     return False\line for _ in range(q):\line     u=int(data[idx]); v=int(data[idx+1]); idx+=2\line     vis=[False]*n\line     print("Yes" if ok(u,v,vis) else "No")\line }\par
