\b C\b0\par
{\f1\fs20 #include <stdio.h>\line #include <stdlib.h>\line \line int cmp(const void* a, const void* b)\{\line     return (*(int*)a - *(int*)b);\line \}\line \line int main()\{\line     int K;\line     if(scanf("%d",&K)!=1) return 0;\line \line     int capacity = 1000;\line     int *all = malloc(capacity * sizeof(int));\line     int total = 0;\line \line     // Read each array\line     for(int i=0;i<K;i++)\{\line         int n;\line         scanf("%d",&n);\line         \line         // Expand if needed\line         while(total + n > capacity)\{\line             capacity *= 2;\line             all = realloc(all, capacity * sizeof(int));\line         \}\line         \line         for(int j=0;j<n;j++)\{\line             scanf("%d",&all[total++]);\line         \}\line     \}\line \line     // Sort all elements\line     qsort(all, total, sizeof(int), cmp);\line \line     // Print merged sorted array\line     for(int i=0;i<total;i++)\{\line         if(i > 0) printf(" ");\line         printf("%d", all[i]);\line     \}\line     printf("\\n");\line \line     free(all);\line     return 0;\line \}\line }\par
