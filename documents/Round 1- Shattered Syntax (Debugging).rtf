{\f1\fs20 import java.io.*;import java.util.*;\line public class Solution\{\line   public static void main(String[] args)throws Exception\{\line     FastScanner fs=new FastScanner(System.in);\line     int r=fs.nextInt(), c=fs.nextInt();\line     long[][] g=new long[r][c];\line     for(int i=0;i<r;i++) for(int j=0;j<c;j++) g[i][j]=fs.nextLong();\line     long[][] dp=new long[r][c];\line     dp[0][0]=0; \line     for(int j=1;j<c;j++) dp[0][j]=dp[0][j-1]+g[0][j];\line     for(int i=1;i<r;i++) dp[i][0]=dp[i-1][0]+g[i][0];\line     for(int i=1;i<r;i++) for(int j=1;j<c;j++)\line       dp[i][j]=g[i][j]+Math.max(dp[i-1][j],dp[i][j-1]); \line     System.out.println(dp[r-1][c-1]);\line   \}\line   static class FastScanner\{\line     private final InputStream in; private final byte[] buf=new byte[1<<16];\line     private int ptr=0,len=0;\line     FastScanner(InputStream is)\{in=is;\}\line     int read() throws IOException\{ if(ptr>=len)\{ len=in.read(buf); ptr=0; if(len<=0) return -1;\} return buf[ptr++];\}\line     int nextInt() throws IOException\{\line       int c; do\{ c=read(); \}while(c<=32);\line       int sgn=1; if(c=='-')\{sgn=-1;c=read();\}\line       int x=0; while(c>32)\{ x=x*10+(c-'0'); c=read(); \}\line       return x*sgn;\line     \}\line     long nextLong() throws IOException\{\line       int c; do\{ c=read(); \}while(c<=32);\line       int sgn=1; if(c=='-')\{sgn=-1;c=read();\}\line       long x=0; while(c>32)\{ x=x*10+(c-'0'); c=read(); \}\line       return x*sgn;\line     \}\line   \}\line \}\line }\par
