  "starter_code": {
    "python": "import sys\n\ndef main():\n    data = sys.stdin.read().strip()\n    if not data:\n        return\n    n = int(data.split()[0])\n    # TODO: build the butterfly pattern lines and print them\n    # print(result)\n\nif __name__ == \"__main__\":\n    main()\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\nint main(){\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n    int n; if(!(cin>>n)) return 0;\n    // TODO: build the butterfly pattern and output\n    return 0;\n}\n",
    "java": "import java.util.*;\npublic class Main {\n    public static void main(String[] args){\n        Scanner sc = new Scanner(System.in);\n        if(!sc.hasNextInt()) return;\n        int n = sc.nextInt();\n        // TODO: build the butterfly pattern and print\n    }\n}\n",
    "c": "#include <stdio.h>\nint main(){\n    int n; if(scanf(\"%d\", &n)!=1) return 0;\n    // TODO: build the butterfly pattern and print\n    return 0;\n}\n"
  },
  "solutions": {
    "python": "def solve(data: str) -> str:\n    n = int(data.strip())\n    lines = []\n    for i in range(1, n + 1):\n        stars = '*' * i\n        spaces = ' ' * (2 * (n - i))\n        lines.append(stars + spaces + stars)\n    for i in range(n, 0, -1):\n        stars = '*' * i\n        spaces = ' ' * (2 * (n - i))\n        lines.append(stars + spaces + stars)\n    return '\\n'.join(lines)\n\n\ndef __main__():\n    import sys\n    data = sys.stdin.read()\n    result = solve(data)\n    if result is None:\n        return\n    sys.stdout.write(str(result))\n\nif __name__ == '__main__':\n    __main__()\n",
    "cpp": "#include <bits/stdc++.h>\nusing namespace std;\n\n#include <bits/stdc++.h>\nusing namespace std;\nstring solve(const string& data) {\n    int n = stoi(data);\n    stringstream out;\n    auto line = [&](int i){ out << string(i,'*') << string(2*(n-i),' ') << string(i,'*'); };\n    for(int i=1;i<=n;i++){ line(i); out << '\\n'; }\n    for(int i=n;i>=1;i--){ line(i); if(i!=1) out << '\\n'; }\n    return out.str();\n}\n\n\nint main() {\n    std::ostringstream ss;\n    ss << std::cin.rdbuf();\n    std::string input = ss.str();\n    std::string output = solve(input);\n    std::cout << output;\n    return 0;\n}\n",
    "java": "import java.io.*;\nimport java.nio.charset.StandardCharsets;\n\npublic class Main {\nstatic class Solution {\n    public String solve(String data) {\n        data = data.trim();\n        if(data.isEmpty()) return \"\";\n        int n = Integer.parseInt(data);\n        StringBuilder sb = new StringBuilder();\n        for (int i = 1; i <= n; i++) { appendLine(sb, n, i); sb.append('\\n'); }\n        for (int i = n; i >= 1; i--) { appendLine(sb, n, i); if (i != 1) sb.append('\\n'); }\n        return sb.toString();\n    }\n    private void appendLine(StringBuilder sb, int n, int i) {\n        for (int k = 0; k < i; k++) sb.append('*');\n        for (int k = 0; k < 2*(n - i); k++) sb.append(' ');\n        for (int k = 0; k < i; k++) sb.append('*');\n    }\n}\n\n\n    public static void main(String[] args) throws Exception {\n        ByteArrayOutputStream baos = new ByteArrayOutputStream();\n        InputStream in = System.in;\n        byte[] buf = new byte[8192];\n        int n;\n        while ((n = in.read(buf)) != -1) {\n            baos.write(buf, 0, n);\n        }\n        String input = baos.toString(StandardCharsets.UTF_8);\n        Solution sol = new Solution();\n        String output = sol.solve(input);\n        if (output != null) {\n            System.out.print(output);\n        }\n    }\n}\n",
    "c": "#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\n#define MAX_INPUT (1 << 20)\n\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\nchar* solve(const char* data) {\n    int n = atoi(data);\n    int total_lines = 2*n;\n    int max_line = 2*n + n;\n    int buf_size = (max_line + 1) * total_lines + 1;\n    char* out = (char*)malloc(buf_size);\n    int pos = 0;\n    for (int i = 1; i <= n; i++) {\n        for (int k = 0; k < i; k++) out[pos++]='*';\n        for (int k = 0; k < 2*(n-i); k++) out[pos++]=' ';\n        for (int k = 0; k < i; k++) out[pos++]='*';\n        out[pos++]='\\n';\n    }\n    for (int i = n; i >= 1; i--) {\n        for (int k = 0; k < i; k++) out[pos++]='*';\n        for (int k = 0; k < 2*(n-i); k++) out[pos++]=' ';\n        for (int k = 0; k < i; k++) out[pos++]='*';\n        if (i != 1) out[pos++]='\\n';\n    }\n    out[pos]='\\0';\n    return out;\n}\n\n\nint main() {\n    char *input = (char *)malloc(MAX_INPUT);\n    if (!input) return 1;\n    size_t len = fread(input, 1, MAX_INPUT - 1, stdin);\n    input[len] = '\\0';\n    char *output = solve(input);\n    if (output) {\n        fputs(output, stdout);\n        free(output);\n    }\n    free(input);\n    return 0;\n}\n"
  }
