# ============================================================================
# Coding Contest Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your production values
# Never commit .env to version control!

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Generate a secure secret key using: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-secrets-token-hex-32

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8080
DEBUG=False

# Set to True only in development
FLASK_ENV=production

# ============================================================================
# DATABASE
# ============================================================================
DB_PATH=data/contest.db

# ============================================================================
# JUDGING CONFIGURATION
# ============================================================================
# Maximum execution time per test case (seconds)
JUDGE_TIMEOUT=5

# Maximum code size (bytes)
MAX_CODE_SIZE=50000

# Maximum output size (bytes)
MAX_OUTPUT_SIZE=10000

# Maximum concurrent judge processes
MAX_CONCURRENT_JUDGES=10

# Number of parallel judge worker threads
NUM_JUDGE_WORKERS=10

# ============================================================================
# RATE LIMITING
# ============================================================================
# Cooldown between submissions (seconds)
SUBMISSION_COOLDOWN=10

# Cooldown between test runs (seconds)
RUN_COOLDOWN=3

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/server.log
LOG_MAX_BYTES=2000000
LOG_BACKUP_COUNT=3

# ============================================================================
# CONTEST SETTINGS
# ============================================================================
# Grace period after contest end for submissions (seconds)
GRACE_PERIOD=30

# Watchdog check interval for stuck submissions (seconds)
WATCHDOG_INTERVAL=60

# Maximum time before submission is considered stuck (seconds)
STUCK_SUBMISSION_TIMEOUT=300

# ============================================================================
# ADMIN SETTINGS
# ============================================================================
# Default admin credentials (CHANGE THESE!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable leaderboard for students
LEADERBOARD_ENABLED=1

# Enable real-time updates via WebSocket
WEBSOCKET_ENABLED=1

